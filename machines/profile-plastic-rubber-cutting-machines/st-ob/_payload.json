es/am3000","machines/2.cable-and-wire-processing-machines/3.am3000",{"title":55,"path":56,"stem":57},"Am5000","/machines/cable-and-wire-processing-machines/am5000","machines/2.cable-and-wire-processing-machines/4.am5000",{"title":59,"path":60,"stem":61},"Triathlon 3000 Triathlon 3000plus","/machines/cable-and-wire-processing-machines/triathlon-3000-triathlon-3000plus","machines/2.cable-and-wire-processing-machines/5.triathlon-3000-triathlon-3000plus",{"title":63,"icon":6,"path":64,"stem":65,"children":66},"Corrugated Conduit","/machines/corrugated-conduit","machines/3.corrugated-conduit/index",[67,68,72],{"title":11,"path":64,"stem":65},{"title":69,"path":70,"stem":71},"Ct4100 Ct4200","/machines/corrugated-conduit/ct4100-ct4200","machines/3.corrugated-conduit/1.ct4100-ct4200",{"title":73,"path":74,"stem":75},"Sm4000","/machines/corrugated-conduit/sm4000","machines/3.corrugated-conduit/2.sm4000",{"title":77,"path":78,"stem":79,"children":80,"icon":6},"Spare Parts & Service","/machines/spare-parts-and-service","machines/4.spare-parts-and-service/index",[81],{"title":82,"path":78,"stem":79},"Spare Parts and Service",{"page":84,"surround":243},{"id":85,"title":86,"body":87,"description":238,"extension":239,"meta":240,"navigation":241,"path":14,"seo":242,"stem":15},"machines/machines/1.profile-plastic-rubber-cutting-machines/1.st-ob.md","Metzner ST-OB",{"type":88,"value":89,"toc":234},"minimal",[90,94,97,100],[91,92,93],"p",{},"The ST-OB is a very well established and extremely robust machine which is versatile in its ability to cut tubes, textiles and extruded profiles to length with high accuracy. Used in a variety of industries from automotive door seals to hoses in the medical industry.",[91,95,96],{},"The machine can be supplied with three interchangeable cutting mechanisms for die cut (kiss cut), tube cut or shear cut. These cutting heads make the ST0OB a very versatile machine with multiple applications.",[91,98,99],{},"Material is pulled into the machine via two feed belts (top and bottom) and these are tensioned by hand to give a good grip without excessive pressure. The pneumatic cylinder, which operated the cutting blade, is specially developed for Metzner, it gives high power for cutting but also vents quickly for a quick cutting speed.",[101,102,103,116],"table",{},[104,105,106],"thead",{},[107,108,109,114],"tr",{},[110,111,113],"th",{"align":112},"center","Performance data",[110,115,13],{},[117,118,119,128,136,144,152,160,166,173,181,189,197,205,211,218,226],"tbody",{},[107,120,121,125],{},[122,123,124],"td",{"align":112},"Material dimensions: width max.",[122,126,127],{},"150 mm / 65 mm",[107,129,130,133],{},[122,131,132],{"align":112},"Material dimensions: height max.",[122,134,135],{},"30 mm / 30 mm",[107,137,138,141],{},[122,139,140],{"align":112},"Feeding speed max.",[122,142,143],{},"60 MPS",[107,145,146,149],{},[122,147,148],{"align":112},"Cutting rate/min. (at cutting length of 5 mm | 0.2″)",[122,150,151],{},"150",[107,153,154,157],{},[122,155,156],{"align":112},"Typically repeatable exactness (depending on material)",[122,158,159],{},"+/- (1 mm + 0.2% L)",[107,161,162,164],{},[122,163],{"align":112},[122,165],{},[107,167,168,171],{},[122,169,170],{"align":112},"Technical data",[122,172],{},[107,174,175,178],{},[122,176,177],{"align":112},"Electrical connection",[122,179,180],{},"230 V; 50/60 Hz; 10 A",[107,182,183,186],{},[122,184,185],{"align":112},"Compressed air connection",[122,187,188],{},"6 bar",[107,190,191,194],{},[122,192,193],{"align":112},"Dimensions (L x W x H)",[122,195,196],{},"700 x 400 x 650 mm",[107,198,199,202],{},[122,200,201],{"align":112},"Weight",[122,203,204],{},"70 kg",[107,206,207,209],{},[122,208],{"align":112},[122,210],{},[107,212,213,216],{},[122,214,215],{"align":112},"Equipment",[122,217],{},[107,219,220,223],{},[122,221,222],{"align":112},"Controls",[122,224,225],{},"Schneider",[107,227,228,231],{},[122,229,230],{"align":112},"Control display",[122,232,233],{},"5.7″ touch and color",{"title":235,"searchDepth":236,"depth":236,"links":237},"",2,[],"The ST-OB is a very well established and extremely robust machine.","md",{},{"title":13},{"title":86,"description":238},[244,246],{"title":11,"path":7,"stem":8,"description":245,"children":-1},"Metzner produce a wide range of machines capable of cutting many different rubber and plastic extrusions.",{"title":17,"path":18,"stem":19,"description":247,"children":-1},"The Variocut is a very versatile cutting machine with a range of exchangeable cutting mechanisms which allows for accurate cut to length of a variety of materials including tubes, hoses, extrusions, pipes, foils, cables and wires.",1738695710210]