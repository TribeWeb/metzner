[{"data":1,"prerenderedAt":111},["ShallowReactive",2],{"navigation":3,"/machines/profile-plastic-rubber-cutting-machines/variocut":83},[4,36,62,76],{"title":5,"icon":6,"path":7,"stem":8,"children":9},"Profile, Plastic & Rubber","i-lucide-star","/machines/profile-plastic-rubber-cutting-machines","machines/1.profile-plastic-rubber-cutting-machines/index",[10,12,16,20,24,28,32],{"title":11,"path":7,"stem":8},"Introduction",{"title":13,"path":14,"stem":15},"ST-OB","/machines/profile-plastic-rubber-cutting-machines/st-ob","machines/1.profile-plastic-rubber-cutting-machines/1.st-ob",{"title":17,"path":18,"stem":19},"Variocut","/machines/profile-plastic-rubber-cutting-machines/variocut","machines/1.profile-plastic-rubber-cutting-machines/2.variocut",{"title":21,"path":22,"stem":23},"KL-BV","/machines/profile-plastic-rubber-cutting-machines/kl-bv","machines/1.profile-plastic-rubber-cutting-machines/3.kl-bv",{"title":25,"path":26,"stem":27},"Mbs","/machines/profile-plastic-rubber-cutting-machines/mbs","machines/1.profile-plastic-rubber-cutting-machines/4.mbs",{"title":29,"path":30,"stem":31},"Dynamat","/machines/profile-plastic-rubber-cutting-machines/dynamat","machines/1.profile-plastic-rubber-cutting-machines/5.dynamat",{"title":33,"path":34,"stem":35},"Ccm","/machines/profile-plastic-rubber-cutting-machines/ccm","machines/1.profile-plastic-rubber-cutting-machines/6.ccm",{"title":37,"icon":6,"path":38,"stem":39,"children":40},"Cable & Wire","/machines/cable-and-wire-processing-machines","machines/2.cable-and-wire-processing-machines/index",[41,42,46,50,54,58],{"title":11,"path":38,"stem":39},{"title":43,"path":44,"stem":45},"Am1000","/machines/cable-and-wire-processing-machines/am1000","machines/2.cable-and-wire-processing-machines/1.am1000",{"title":47,"path":48,"stem":49},"Am2000","/machines/cable-and-wire-processing-machines/am2000","machines/2.cable-and-wire-processing-machines/2.am2000",{"title":51,"path":52,"stem":53},"Am3000","/machines/cable-and-wire-processing-machines/am3000","machines/2.cable-and-wire-processing-machines/3.am3000",{"title":55,"path":56,"stem":57},"Am5000","/machines/cable-and-wire-processing-machines/am5000","machines/2.cable-and-wire-processing-machines/4.am5000",{"title":59,"path":60,"stem":61},"Triathlon 3000 Triathlon 3000plus","/machines/cable-and-wire-processing-machines/triathlon-3000-triathlon-3000plus","machines/2.cable-and-wire-processing-machines/5.triathlon-3000-triathlon-3000plus",{"title":63,"icon":6,"path":64,"stem":65,"children":66},"Corrugated Conduit","/machines/corrugated-conduit","machines/3.corrugated-conduit/index",[67,68,72],{"title":11,"path":64,"stem":65},{"title":69,"path":70,"stem":71},"Ct4100 Ct4200","/machines/corrugated-conduit/ct4100-ct4200","machines/3.corrugated-conduit/1.ct4100-ct4200",{"title":73,"path":74,"stem":75},"Sm4000","/machines/corrugated-conduit/sm4000","machines/3.corrugated-conduit/2.sm4000",{"title":77,"path":78,"stem":79,"children":80,"icon":6},"Spare Parts & Service","/machines/spare-parts-and-service","machines/4.spare-parts-and-service/index",[81],{"title":82,"path":78,"stem":79},"Spare Parts and Service",{"page":84,"surround":106},{"id":85,"title":86,"body":87,"description":101,"extension":102,"meta":103,"navigation":104,"path":18,"seo":105,"stem":19},"machines/machines/1.profile-plastic-rubber-cutting-machines/2.variocut.md","Metzner Variocut",{"type":88,"value":89,"toc":97},"minimal",[90,94],[91,92,93],"p",{},"The pneumatic cutting mechanism is capable of up to 140 cuts per minute and the twin feed belts gently clamping the material and feeding it through the machine in a way that gives highly repeatable results.",[91,95,96],{},"The infeed of the Variocut allows for cutting of materials up to 95mm wide and 30mmhigh. Also with it’s extremely simple operation, once the belt feed has been lowered,the material is clamped automatically. The pressure, provided by a pneumatic system, prevents any slippage so that the operator does not have anything to adjust. Tools changing is equally easy, the tools are inserted and removed by hand, no other adjustment is necessary.",{"title":98,"searchDepth":99,"depth":99,"links":100},"",2,[],"The Variocut is a very versatile cutting machine with a range of exchangeable cutting mechanisms which allows for accurate cut to length of a variety of materials including tubes, hoses, extrusions, pipes, foils, cables and wires.","md",{},{"title":17},{"title":86,"description":101},[107,109],{"title":13,"path":14,"stem":15,"description":108,"children":-1},"The ST-OB is a very well established and extremely robust machine.",{"title":21,"path":22,"stem":23,"description":110,"children":-1},"The KL-BV was developed for cutting stretchy or very soft materials such as silicone. Widely used in the medical industry, it can cut highly elastic materials precisely and to a very accurate length.",1738695710210]